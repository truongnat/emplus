{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Token Schema",
  "description": "Schema for design tokens used in the theme system",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "tokens": {
      "type": "object",
      "properties": {
        "color": {
          "type": "object",
          "properties": {
            "primary": { "$ref": "#/definitions/colorToken" },
            "primaryDeep": { "$ref": "#/definitions/colorToken" },
            "primarySoft": { "$ref": "#/definitions/colorToken" },
            "accent": { "$ref": "#/definitions/colorToken" },
            "secondary": { "$ref": "#/definitions/colorToken" },
            "ink": { "$ref": "#/definitions/colorToken" },
            "muted": { "$ref": "#/definitions/colorToken" },
            "white": { "$ref": "#/definitions/colorToken" },
            "black": { "$ref": "#/definitions/colorToken" },
            "slate": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/colorToken" }
            },
            "semantic": {
              "type": "object",
              "properties": {
                "danger": { "$ref": "#/definitions/colorToken" },
                "success": { "$ref": "#/definitions/colorToken" },
                "warning": { "$ref": "#/definitions/colorToken" },
                "info": { "$ref": "#/definitions/colorToken" }
              }
            },
            "glass": {
              "type": "object",
              "properties": {
                "glass": { "$ref": "#/definitions/colorToken" },
                "glassStrong": { "$ref": "#/definitions/colorToken" },
                "glassBorder": { "$ref": "#/definitions/colorToken" }
              }
            }
          }
        },
        "space": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/spaceToken" }
        },
        "size": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/sizeToken" }
        },
        "radius": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/radiusToken" }
        },
        "zIndex": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/zIndexToken" }
        },
        "typography": {
          "type": "object",
          "properties": {
            "fontFamily": {
              "type": "object",
              "properties": {
                "heading": { "$ref": "#/definitions/fontFamilyToken" },
                "body": { "$ref": "#/definitions/fontFamilyToken" },
                "mono": { "$ref": "#/definitions/fontFamilyToken" }
              }
            },
            "fontSize": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/fontSizeToken" }
            },
            "lineHeight": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/lineHeightToken" }
            },
            "fontWeight": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/fontWeightToken" }
            }
          }
        },
        "shadow": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/shadowToken" }
        },
        "breakpoint": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/breakpointToken" }
        }
      }
    },
    "themes": {
      "type": "object",
      "properties": {
        "light": { "$ref": "#/definitions/theme" },
        "dark": { "$ref": "#/definitions/theme" }
      }
    }
  },
  "definitions": {
    "colorToken": {
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "type": { "type": "string", "enum": ["color"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "spaceToken": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["spacing"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "sizeToken": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["size"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "radiusToken": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["borderRadius"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "zIndexToken": {
      "type": "object",
      "properties": {
        "value": { "type": "integer" },
        "type": { "type": "string", "enum": ["zIndex"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "fontFamilyToken": {
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "type": { "type": "string", "enum": ["fontFamily"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "fontSizeToken": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["fontSize"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "lineHeightToken": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["lineHeight"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "fontWeightToken": {
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "type": { "type": "string", "enum": ["fontWeight"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "shadowToken": {
      "type": "object",
      "properties": {
        "value": {
          "type": "object",
          "properties": {
            "offsetX": { "type": "number" },
            "offsetY": { "type": "number" },
            "blur": { "type": "number" },
            "spread": { "type": "number" },
            "color": { "type": "string" }
          }
        },
        "type": { "type": "string", "enum": ["shadow"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "breakpointToken": {
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "type": { "type": "string", "enum": ["breakpoint"] },
        "description": { "type": "string" }
      },
      "required": ["value"]
    },
    "theme": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
