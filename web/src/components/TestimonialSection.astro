---
interface Testimonial {
  quote: string;
  author: string;
  role: string;
  rating: number;
}

const testimonials: Testimonial[] = [
  {
    quote: 'Em+ giúp chúng mình gần nhau hơn dù ở xa. Tính năng đồng thời gian là thứ chúng mình yêu thích nhất!',
    author: 'Minh & Linh',
    role: 'Cặp đôi 2 năm',
    rating: 5,
  },
  {
    quote: 'Quản lý chi tiêu chung chưa bao giờ dễ dàng như vậy. Không còn cải nhau vì tiền nữa!',
    author: 'Đức & Trang',
    role: 'Cặp đôi 3 năm',
    rating: 5,
  },
  {
    quote: 'Giao diện đẹp, mượt mà. Mỗi ngày đều muốn mở app lên để xem tâm trạng của người yêu.',
    author: 'Huy & Nhi',
    role: 'Cặp đôi 1 năm',
    rating: 5,
  },
  {
    quote: 'Tụi mình đặt nhắc ngày kỷ niệm và mấy “thói quen nhỏ”. Nghe đơn giản mà hiệu quả thật.',
    author: 'Khoa & Vy',
    role: 'Cặp đôi yêu xa',
    rating: 5,
  },
  {
    quote: 'Timeline kỷ niệm kiểu nhật ký giúp tụi mình nhìn lại dễ thương ghê. Mỗi tuần thêm một chút.',
    author: 'Tùng & My',
    role: 'Cặp đôi 4 năm',
    rating: 5,
  },
  {
    quote: 'Cảm giác “đồng bộ” làm mình yên tâm hơn. Không phải kiểm soát, chỉ là kết nối đúng lúc.',
    author: 'Phúc & An',
    role: 'Cặp đôi 18 tháng',
    rating: 5,
  },
  {
    quote: 'App không làm màu, dùng hằng ngày rất “vừa”. Thấy mối quan hệ được chăm sóc đều hơn.',
    author: 'Nam & Hạ',
    role: 'Cặp đôi 2.5 năm',
    rating: 5,
  },
];

const track = [...testimonials, ...testimonials];
---

<section class="py-20 md:py-28 bg-muted/30">
  <div class="container">
    <!-- Section header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Được các cặp đôi
        <span class="text-primary">tin tưởng</span>
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Những chia sẻ từ các cặp đôi đang sử dụng Em+
      </p>
    </div>

    <!-- Auto-scrolling carousel (pause on hover/focus). Manual scroll on reduced motion. -->
    <div class="relative mx-auto max-w-6xl">
      <div class="pointer-events-none absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-muted/30 to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-muted/30 to-transparent"></div>

      <div
        class="carousel group overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none]"
        aria-label="Testimonials carousel"
      >
        <div class="track flex gap-6 py-2">
          {track.map((testimonial, i) => (
            <article
              class="card w-[320px] sm:w-[360px] shrink-0 rounded-xl border border-border/40 bg-card/40 backdrop-blur-sm p-6"
              aria-label={`Testimonial ${i + 1}`}
            >
              <div class="flex gap-1 mb-4" aria-hidden="true">
                {Array.from({ length: testimonial.rating }).map(() => (
                  <span class="text-yellow-400">★</span>
                ))}
              </div>

              <blockquote class="text-sm text-foreground leading-relaxed mb-4">
                “{testimonial.quote}”
              </blockquote>

              <div>
                <p class="font-semibold text-sm">{testimonial.author}</p>
                <p class="text-xs text-muted-foreground">{testimonial.role}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .carousel::-webkit-scrollbar {
    display: none;
  }

  .track {
    width: max-content;
    animation: marquee 38s linear infinite;
  }

  .group:hover .track,
  .group:focus-within .track {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
  }
</style>
