---
const scenarios = [
  {
    title: 'Bạn từng quên một ngày quan trọng',
    description:
      'Em+ hữu ích nhất khi bạn không muốn xin lỗi lần thứ hai chỉ vì đã nhớ ra quá muộn.',
  },
  {
    title: 'Bạn muốn quan tâm hơn nhưng không biết bắt đầu từ đâu',
    description:
      'Thay vì đợi đến lúc có lỗi, Em+ gợi ý một bước nhỏ đủ dễ để làm ngay trong hôm nay.',
  },
  {
    title: 'Bạn hay nhớ cảm xúc nhưng quên chi tiết',
    description:
      'Những điều như món thích ăn, dịp nên chuẩn bị hay kiểu quan tâm hợp với người ấy đều có chỗ để giữ lại.',
  },
];
---

<section class="bg-muted/45 py-18 md:py-24">
  <div class="container">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Em+ hợp nhất với những lúc
        <span class="block text-primary">rất bình thường nhưng dễ làm mình vô tâm</span>
      </h2>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        Đây không phải một mạng xã hội cho các cặp đôi. Đây là một công cụ nhẹ để bạn đừng bỏ sót những điều nhỏ nhưng quan trọng, trước hết là từ phía bạn.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {scenarios.map((scenario) => (
        <article class="rounded-3xl border border-border/80 bg-card/95 p-6 shadow-sm">
          <div class="inline-flex rounded-full border border-secondary/10 bg-secondary/10 px-3 py-1 text-xs font-semibold text-secondary">
            Tình huống thực tế
          </div>
          <h3 class="mt-4 text-xl font-semibold tracking-tight text-foreground">
            {scenario.title}
          </h3>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            {scenario.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
