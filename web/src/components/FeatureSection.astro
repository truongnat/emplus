---
interface Feature {
  id: string;
  title: string;
  description: string;
  icon: string;
}

const pillars = [
  {
    eyebrow: 'Bắt đầu',
    title: 'Bạn có thể dùng một mình ngay từ ngày đầu',
    description: 'Không cần chờ người ấy cùng vào app mới có giá trị. Em+ đã hữu ích từ ngày đầu tiên bạn muốn nhớ tốt hơn.',
  },
  {
    eyebrow: 'Nhớ',
    title: 'Ngày quan trọng không còn bị trôi mất',
    description: 'Sinh nhật, ngày đầu yêu, các dịp riêng của hai người đều được kéo lên đúng lúc.',
  },
  {
    eyebrow: 'Gợi ý',
    title: 'Bạn luôn biết hôm nay nên làm gì',
    description: 'Không phải viết một bài dài. Chỉ cần một hành động nhỏ, đúng thời điểm.',
  },
  {
    eyebrow: 'Quan tâm',
    title: 'Những điều nhỏ được giữ lại thay vì đoán lại',
    description: 'Sở thích, mốc riêng và những điều đáng nhớ về người ấy luôn ở đúng chỗ bạn cần.',
  },
];

const features: Feature[] = [
  {
    id: 'dates',
    title: 'Những ngày cần nhớ',
    description: 'Nhắc sớm để bạn có thời gian chuẩn bị, thay vì xin lỗi khi đã trễ.',
    icon: '01',
  },
  {
    id: 'memory',
    title: 'Điều nên nhớ về người ấy',
    description: 'Một nơi nhẹ nhàng để lưu lại những chi tiết rất nhỏ nhưng rất dễ quên.',
    icon: '02',
  },
  {
    id: 'suggestion',
    title: 'Một gợi ý vừa đủ cho hôm nay',
    description: 'Em+ không bắt bạn phải làm nhiều. Chỉ đề xuất một bước nhỏ, đủ dễ để làm ngay.',
    icon: '03',
  },
  {
    id: 'privacy',
    title: 'Nhắc đúng lúc, riêng tư vừa đủ',
    description: 'Nhẹ nhàng và cá nhân. Không biến chuyện tình cảm của bạn thành một feed xã hội.',
    icon: '04',
  },
  {
    id: 'pairing',
    title: 'Ghép đôi khi cả hai đã sẵn sàng',
    description: 'Khi muốn đi xa hơn, hai bạn có thể đồng bộ ngày quan trọng và nhắc nhở chung mà không phải bắt đầu lại từ đầu.',
    icon: '05',
  },
];
---

<section id="features" class="py-18 md:py-24">
  <div class="container">
    <div class="mx-auto mb-10 max-w-3xl text-center md:mb-14">
      <h2 data-reveal class="reveal text-3xl font-semibold tracking-tight sm:text-4xl">
        Không phải thêm thật nhiều tính năng.
        <span class="block text-primary">Chỉ là đúng thứ cần thiết.</span>
      </h2>
      <p data-reveal class="reveal mt-4 text-lg leading-8 text-muted-foreground [--reveal-delay:90ms]">
        Em+ được làm cho những lúc rất đời thường: sắp đến dịp quan trọng, muốn quan tâm nhưng chưa biết bắt đầu từ đâu, hoặc chỉ sợ mình quên mất một điều đáng ra nên nhớ.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
      {pillars.map((pillar, index) => (
        <article
          data-reveal
          class="reveal rounded-3xl border border-border/80 bg-card/90 p-6 shadow-sm"
          style={`--reveal-delay:${index * 70}ms`}
        >
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
            {pillar.eyebrow}
          </p>
          <h3 class="mt-3 text-xl font-semibold tracking-tight text-foreground">
            {pillar.title}
          </h3>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            {pillar.description}
          </p>
        </article>
      ))}
    </div>

    <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      {features.map((feature, index) => (
        <article
          data-reveal
          class="reveal rounded-3xl border border-border/80 bg-card/90 p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-primary/20"
          style={`--reveal-delay:${index * 80}ms`}
        >
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-primary/10 text-sm font-semibold text-primary">
            {feature.icon}
          </div>
          <h3 class="mt-4 text-xl font-semibold tracking-tight text-foreground">
            {feature.title}
          </h3>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            {feature.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
