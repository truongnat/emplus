---
import { siteDescription } from '@/lib/site';
import { androidAppUrl, iosAppUrl } from '@/lib/site';

const iosHref = iosAppUrl() ?? '#download';
const androidHref = androidAppUrl() ?? '#download';
const primaryHref = iosHref !== '#download' ? iosHref : androidHref;

const checklist = [
  {
    label: 'Kỷ niệm sắp tới',
    title: 'Còn 3 ngày đến ngày đầu yêu',
    detail: 'Em+ nhắc sớm để bạn không phải xoay xở phút cuối.',
  },
  {
    label: 'Điều cần nhớ',
    title: 'Người ấy thích thư tay hơn quà phô trương',
    detail: 'Những chi tiết nhỏ được giữ lại ở nơi bạn dễ tìm nhất.',
  },
  {
    label: 'Gợi ý hôm nay',
    title: 'Nhắn một câu ngắn trước 22:00',
    detail: 'Đủ nhẹ để làm ngay, đủ đúng để tạo khác biệt.',
  },
];
---

<section class="relative overflow-hidden py-18 md:py-24 lg:py-28">
  <div class="absolute inset-x-0 top-0 -z-10 h-[30rem]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,hsl(var(--primary)/0.16),transparent_34%),radial-gradient(circle_at_top_right,hsl(var(--secondary)/0.12),transparent_30%)]"></div>
  </div>

  <div class="container">
    <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 lg:grid-cols-[1.02fr_0.98fr]">
      <div class="text-center lg:text-left">
        <div data-reveal class="reveal mb-6 inline-flex items-center gap-2 rounded-full border border-border/80 bg-card/80 px-4 py-2 text-sm text-muted-foreground shadow-sm">
          <span class="inline-flex h-2.5 w-2.5 rounded-full bg-primary"></span>
          <span>Cho người đang yêu nhưng không muốn quên những điều nhỏ, kể cả khi bắt đầu một mình</span>
        </div>

        <h1 data-reveal class="reveal text-4xl font-semibold tracking-tight text-foreground sm:text-5xl md:text-6xl [--reveal-delay:70ms]">
          Nhớ đúng lúc.
          <span class="block text-primary">Quan tâm đúng cách.</span>
        </h1>

        <p data-reveal class="reveal mt-6 max-w-2xl text-lg leading-8 text-muted-foreground lg:mx-0 [--reveal-delay:120ms]">
          {siteDescription}
          {' '}
          Em+ giúp bạn giữ những ngày quan trọng, những điều nên nhớ về người ấy,
          và một gợi ý nhỏ để hôm nay không trôi qua vô tâm. Khi cả hai đã sẵn sàng,
          pairing sẽ giúp đồng bộ trải nghiệm chung.
        </p>

        <div data-reveal class="reveal mt-9 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start [--reveal-delay:180ms]">
          <a
            href={primaryHref}
            target={primaryHref.startsWith('http') ? '_blank' : undefined}
            rel={primaryHref.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
          >
            Bắt đầu với Em+
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-card px-8 py-3.5 text-base font-semibold text-foreground transition hover:border-primary/25 hover:bg-card/90"
          >
            Xem cách Em+ giúp
          </a>
        </div>

        <div data-reveal class="reveal mt-5 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-muted-foreground lg:justify-start [--reveal-delay:230ms]">
          <span>Miễn phí để bắt đầu</span>
          <span class="hidden h-1 w-1 rounded-full bg-border sm:inline-flex"></span>
          <span>Dùng một mình trước, ghép đôi sau nếu thấy cần</span>
        </div>
      </div>

      <div data-reveal class="reveal relative mx-auto w-full max-w-xl [--reveal-delay:210ms]">
        <div class="rounded-[30px] border border-border/80 bg-card/95 p-5 shadow-sm md:p-6">
          <div class="mb-4 flex items-start justify-between gap-4">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                Hôm nay trong Em+
              </p>
              <h2 class="mt-2 text-[1.55rem] font-semibold tracking-tight text-foreground md:text-[1.7rem]">
                Một nơi để không bỏ sót điều quan trọng
              </h2>
            </div>
            <span class="inline-flex rounded-full border border-primary/15 bg-primary/5 px-3 py-1 text-xs font-semibold text-primary">
              Solo-first
            </span>
          </div>

          <div class="space-y-2.5">
            {checklist.map((item) => (
              <div class="rounded-2xl border border-border/80 bg-background/90 px-4 py-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                  {item.label}
                </p>
                <p class="mt-2 text-base font-semibold tracking-tight text-foreground">
                  {item.title}
                </p>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  {item.detail}
                </p>
              </div>
            ))}
          </div>

          <div class="mt-4 rounded-2xl border border-primary/15 bg-primary/5 px-4 py-4">
            <p class="text-sm font-medium text-foreground">
              Không cần chờ pairing mới bắt đầu.
            </p>
            <p class="mt-1 text-sm leading-6 text-muted-foreground">
              Dùng một mình đã có ích. Pairing chỉ làm nhắc nhở và bối cảnh chung liền mạch hơn.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
