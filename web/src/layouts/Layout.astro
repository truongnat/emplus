---
import '@/styles/global.css';
import { siteDescription, siteName, siteUrl } from '@/lib/site';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  articleDate?: Date;
}

const {
  title,
  description = siteDescription,
  ogType = 'website',
  articleDate,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, siteUrl()).href;
const fullTitle = title === siteName ? siteName : `${title} · ${siteName}`;
---

<!doctype html>
<html lang="vi" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="vi_VN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {
      articleDate ? (
        <meta
          property="article:published_time"
          content={articleDate.toISOString()}
        />
      ) : null
    }
    <script is:inline>
      (function () {
        try {
          var d = document.documentElement;
          var stored = localStorage.getItem('emplus-theme');
          var prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)',
          ).matches;
          if (stored === 'light' || (!stored && !prefersDark)) {
            d.classList.remove('dark');
          } else {
            d.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to main content link -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-3 focus:py-2 focus:text-primary-foreground"
      >Bỏ qua nội dung</a
    >

    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-border/40 bg-card/40 backdrop-blur supports-[backdrop-filter]:bg-card/30">
      <div class="container flex flex-wrap items-center justify-between gap-4 py-4">
        <!-- Logo -->
        <a href="/" class="text-lg font-bold text-foreground flex items-center gap-2">
          <span>❤️</span>
          <span>{siteName}</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex flex-wrap items-center gap-6 text-sm text-muted-foreground">
          <a href="/#features" class="transition hover:text-foreground">Tính năng</a>
          <a href="/blog" class="transition hover:text-foreground">Blog</a>
          <a href="/privacy" class="transition hover:text-foreground">Chính sách</a>
          <a href="/terms" class="transition hover:text-foreground">Điều khoản</a>
          <a href="/rss.xml" class="transition hover:text-foreground">RSS</a>
        </nav>

        <!-- Theme Toggle + Mobile Menu -->
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="theme-toggle"
            class="rounded-md border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition hover:bg-muted"
            aria-label="Đổi giao diện sáng/tối"
          >
            🌙
          </button>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden rounded-md border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground"
            aria-label="Menu"
          >
            ☰
          </button>
        </div>
      </div>

      <!-- Mobile Nav (hidden by default) -->
      <nav
        id="mobile-menu"
        class="hidden md:hidden border-t border-border/40 bg-card/50 backdrop-blur"
      >
        <div class="container flex flex-col gap-3 py-4 text-sm text-muted-foreground">
          <a href="/#features" class="transition hover:text-foreground">Tính năng</a>
          <a href="/blog" class="transition hover:text-foreground">Blog</a>
          <a href="/privacy" class="transition hover:text-foreground">Chính sách</a>
          <a href="/terms" class="transition hover:text-foreground">Điều khoản</a>
          <a href="/rss.xml" class="transition hover:text-foreground">RSS</a>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main id="main" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border/40 bg-card/30 backdrop-blur">
      <div class="container py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <!-- Brand column -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xl">❤️</span>
              <span class="text-lg font-bold">{siteName}</span>
            </div>
            <p class="text-sm text-muted-foreground max-w-xs">
              {siteDescription}
            </p>
          </div>

          <!-- Product links -->
          <div>
            <h3 class="font-semibold mb-4">Sản phẩm</h3>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="/#features" class="text-muted-foreground hover:text-foreground transition">
                  Tính năng
                </a>
              </li>
              <li>
                <a href="#download" class="text-muted-foreground hover:text-foreground transition">
                  Tải ứng dụng
                </a>
              </li>
              <li>
                <a href="/blog" class="text-muted-foreground hover:text-foreground transition">
                  Blog
                </a>
              </li>
            </ul>
          </div>

          <!-- Legal links -->
          <div>
            <h3 class="font-semibold mb-4">Pháp lý</h3>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="/privacy" class="text-muted-foreground hover:text-foreground transition">
                  Chính sách bảo mật
                </a>
              </li>
              <li>
                <a href="/terms" class="text-muted-foreground hover:text-foreground transition">
                  Điều khoản dịch vụ
                </a>
              </li>
              <li>
                <a href="/rss.xml" class="text-muted-foreground hover:text-foreground transition">
                  RSS Feed
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Copyright -->
        <div class="border-t border-border/40 pt-8 text-center text-sm text-muted-foreground">
          &copy; {new Date().getFullYear()} {siteName} · Mọi quyền được bảo lưu
        </div>
      </div>
    </footer>

    <!-- Scripts -->
    <script is:inline>
      // Theme toggle
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function () {
          var d = document.documentElement;
          var next = d.classList.contains('dark') ? 'light' : 'dark';
          if (next === 'dark') {
            d.classList.add('dark');
          } else {
            d.classList.remove('dark');
          }
          try {
            localStorage.setItem('emplus-theme', next);
          } catch (_) {}
        });
      }

      // Mobile menu toggle
      var menuBtn = document.getElementById('mobile-menu-btn');
      var mobileMenu = document.getElementById('mobile-menu');
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', function () {
          mobileMenu.classList.toggle('hidden');
        });

        // Close menu when a link is clicked
        var links = mobileMenu.querySelectorAll('a');
        links.forEach(function (link) {
          link.addEventListener('click', function () {
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
