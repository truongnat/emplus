---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Không tìm thấy" description="Trang không tồn tại.">
  <div class="mx-auto max-w-lg text-center">
    <h1 class="text-2xl font-bold">404</h1>
    <p class="mt-2 text-muted-foreground">Không tìm thấy trang bạn yêu cầu.</p>
    <a
      href="/"
      class="mt-6 inline-flex rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground"
      >Về trang chủ</a
    >
  </div>
</Layout>
