# =============================================================================
# Em+ API — production environment (full template)
#
# Khớp `docker-compose.yml` ở **root repo** (services: `postgres`, `redis`, `minio`, …).
#
# Cách dùng:
#   cp api/.env.production.example api/.env.production
#   điền DATA_ENCRYPTION_KEY + SMTP (Gmail bạn tự cấu hình) + MINIO_PUBLIC_BASE_URL khi có.
#
# Không commit `api/.env.production` (đã ignore ở root `.gitignore`).
# Không dán URL/password production thật (Supabase, v.v.) vào file *example* này.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

NODE_ENV=production
DATA_STORE=postgres

# Cổng API (Caddy/nginx reverse_proxy tới đây)
PORT=3000

# -----------------------------------------------------------------------------
# PostgreSQL — service name `postgres` (cùng Docker network với API)
#
# Compose mặc định:
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=postgres
#   POSTGRES_DB=emplus
#   container port: 5432 (mapping host là tuỳ chọn)
#
# Khi API chạy **trong** Docker và **cùng network** với stack compose (tên project
# ví dụ `emplus`), DNS nội bộ resolve được hostname đúng bằng **tên service**:
#   postgres, redis, minio
#
# Khi API chạy **trên host** (bun) hoặc container **không** join network đó:
#   dùng 127.0.0.1 + cổng đã publish (vd. 5432), ví dụ:
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/emplus?sslmode=disable
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/emplus?sslmode=disable

# Replica — service `postgres-slave` trong compose (port nội bộ container luôn 5432)
# READ_DATABASE_URL=postgresql://postgres:postgres@postgres-slave:5432/emplus?sslmode=disable

# -----------------------------------------------------------------------------
# Redis — service name `redis` (cùng network, không password trong compose mẫu)
# -----------------------------------------------------------------------------

REDIS_URL=redis://redis:6379

# Host mode (API không trong compose network):
# REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

CORS_ALLOWED_ORIGINS=https://emplus.truongsoftware.com,https://emplus-api.truongsoftware.com

# -----------------------------------------------------------------------------
# Mã hoá (bắt buộc production) — chỉ tạo trên server:
#   openssl rand -hex 32
# -----------------------------------------------------------------------------

DATA_ENCRYPTION_KEY=__RUN_openssl_rand_hex_32_ON_SERVER__

# -----------------------------------------------------------------------------
# SMTP — Gmail / provider (bạn cấu hình sau)
# -----------------------------------------------------------------------------

MAIL_HOST=__YOUR_SMTP_HOST__
MAIL_PORT=587
MAIL_USER=__YOUR_SMTP_USER__
MAIL_PASS=__YOUR_SMTP_APP_PASSWORD__
MAIL_FROM=Em+ <__YOUR_FROM_EMAIL__>
SIGNUP_ALERT_EMAILS=__DEV_OR_ADMIN_EMAILS_COMMA_SEPARATED__

# -----------------------------------------------------------------------------
# MinIO — service name `minio` (cùng network)
#
# Compose: MINIO_ROOT_USER=minioadmin, MINIO_ROOT_PASSWORD=minioadmin,
# API S3 trong container: port 9000, bucket `emplus` (sau minio-init).
#
# MINIO_ENDPOINT: URL **process API** gọi MinIO → trong compose dùng http://minio:9000
#
# MINIO_PUBLIC_BASE_URL: URL **mobile/browser** tải object công khai — không thể
# là `minio:9000` (chỉ tồn tại trong Docker). Cần domain + TLS (hoặc IP:port có chủ đích).
# -----------------------------------------------------------------------------

MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=emplus
MINIO_USE_SSL=false

# MINIO_PUBLIC_BASE_URL=https://emplus-storage.truongsoftware.com

# API ngoài compose network (gọi MinIO qua port publish ra host):
# MINIO_ENDPOINT=http://127.0.0.1:9000

# -----------------------------------------------------------------------------
# OAuth (mobile)
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_IDS=
APPLE_AUDIENCES=

# -----------------------------------------------------------------------------
# Swagger
# -----------------------------------------------------------------------------

SWAGGER_ENABLED=false
SWAGGER_PATH=/v1/docs

# -----------------------------------------------------------------------------
# Demo data — tắt production
# -----------------------------------------------------------------------------

FAKE_IN_APP_NOTIFICATIONS=false
FAKE_TIMELINE_MEMORIES=false

# -----------------------------------------------------------------------------

DEFAULT_BUDGET_AMOUNT=20000

# -----------------------------------------------------------------------------
# Logging (tuỳ chọn)
# -----------------------------------------------------------------------------

# LOKI_URL=http://localhost:3100
