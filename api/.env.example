# API Environment Variables
NODE_ENV=development
DATA_STORE=postgres

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emplus?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Mail
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@emplus.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://127.0.0.1:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/v1/docs

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=emplus
MINIO_USE_SSL=false

# OAuth
GOOGLE_CLIENT_IDS=
APPLE_AUDIENCES=

# Budget
DEFAULT_BUDGET_AMOUNT=20000
