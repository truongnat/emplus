# API Environment Variables
NODE_ENV=development
DATA_STORE=postgres

# In-app notifications: khi development, user mới (0 thông báo) sẽ được seed vài bản demo ở GET /v1/notifications.
# Tắt hẳn: FAKE_IN_APP_NOTIFICATIONS=false
# Bật ngoài development: FAKE_IN_APP_NOTIFICATIONS=true

# Timeline: development — couple chưa có memory → GET /v1/timeline/memories seed 10 demo (đủ tag lọc).
# FAKE_TIMELINE_MEMORIES=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emplus

# Redis
REDIS_URL=redis://localhost:6379

# Mail
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@emplus.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://127.0.0.1:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/v1/docs

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=emplus
MINIO_USE_SSL=false
# URL gốc mà app thiết bị thật tải ảnh được (LAN IP nếu cần). Mặc định dùng origin của MINIO_ENDPOINT.
# MINIO_PUBLIC_BASE_URL=http://192.168.1.10:9000

# OAuth
GOOGLE_CLIENT_IDS=
APPLE_AUDIENCES=

# Budget
DEFAULT_BUDGET_AMOUNT=20000
