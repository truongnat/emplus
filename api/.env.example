# Chế độ lưu trữ API: memory | postgres
DATA_STORE=postgres

# Bắt buộc khi DATA_STORE=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emplus
READ_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/emplus
REDIS_URL=redis://localhost:6379

# Máy chủ email local (Mailpit)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@emplus.local

# Lưu trữ đối tượng MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=emplus
MINIO_USE_SSL=false

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/v1/docs

# OAuth (chỉ cho môi trường thật; mock chỉ dành cho môi trường test)
ALLOW_MOCK_OAUTH=false
# Danh sách cách nhau bằng dấu phẩy (client ID cho mobile/web)
GOOGLE_CLIENT_IDS=
APPLE_AUDIENCES=
# Trường đơn lẻ để tương thích ngược
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_ISSUER=https://appleid.apple.com

# Tùy chọn: client ID tường minh cho lệnh chạy dev web/mobile
WEB_GOOGLE_CLIENT_ID=
MOBILE_GOOGLE_EXPO_CLIENT_ID=
MOBILE_GOOGLE_ANDROID_CLIENT_ID=
MOBILE_GOOGLE_IOS_CLIENT_ID=
MOBILE_GOOGLE_WEB_CLIENT_ID=

# Máy chủ
PORT=3000
